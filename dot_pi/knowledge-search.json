{
  "dirs": [
    "~/personal/SecondBrain"
  ],
  "fileExtensions": [
    ".md",
    ".txt"
  ],
  "excludeDirs": [
    "node_modules",
    ".git",
    ".obsidian",
    ".trash",
    "PDFs",
    "Excalidraw"
  ],
  "provider": {
    "type": "ollama",
    "url": "http://127.0.0.1:11434",
    "model": "nomic-embed-text"
  },
  "overview": {
    "inject": true,
    "maxDepth": 2,
    "maxFoldersPerDir": 20,
    "maxKeywordsPerFolder": 5
  }
}
