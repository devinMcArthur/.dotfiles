[Default]
save_dir=$HOME/Pictures/Screenshots
save_filename_format=screenshot-%Y%m%d-%H%M%S.png
show_panel=true
line_size=4
text_size=20
text_font=JetBrainsMono Nerd Font
paint_mode=brush
# Exit immediately after Save or Copy (Ctrl+S / Ctrl+C / button click) instead
# of staying open until Escape. Annotation flow becomes: Super+S -> draw ->
# Ctrl+C -> done, on clipboard. wl-clip-persist keeps the offer alive after
# swappy exits.
early_exit=true
fill_shape=false
