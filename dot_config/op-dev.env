# Dev secrets — referenced by 1Password CLI, not stored here.
#
# Used via:  op run --env-file=~/.config/op-dev.env -- <cmd>
# Or via the `with-secrets <cmd>` shell function defined in .zshrc.
#
# `op run` resolves the op:// URIs at runtime and injects them as env vars
# into the child process. The literal values never touch disk.

ANTHROPIC_API_KEY="op://Dev Secrets/anthropic_api_key/credential"
