{{- if eq .chezmoi.os "linux" -}}
{{- if eq .chezmoi.osRelease.id "arch" -}}
#!/usr/bin/env bash
# Installs all packages required by the dotfiles.
# chezmoi run_onchange_*: re-runs whenever this rendered script changes,
# i.e. whenever the package lists below are edited.
# Idempotent: pacman/yay --needed skips already-installed packages.

set -euo pipefail

PACMAN_PKGS=(
  # Shell & prompt
  zsh starship

  # Multiplexers & editor
  tmux zellij neovim

  # Terminal & WM
  ghostty
  hyprland hypridle hyprlock hyprpaper hyprpicker hyprshot hyprpolkitagent

  # XDG desktop portals (screen-sharing, file pickers, etc. for sandboxed apps)
  xdg-desktop-portal xdg-desktop-portal-hyprland xdg-desktop-portal-gtk
  waybar wofi swaync

  # Wayland clipboard + history + screenshot annotation + media control
  cliphist wl-clipboard swappy grim slurp playerctl brightnessctl

  # Login / display manager (regreet = GTK4 greeter, cage = embedded
  # Wayland kiosk compositor that hosts it; tuigreet kept as fallback)
  greetd greetd-regreet cage greetd-tuigreet

  # Fingerprint reader
  fprintd libfprint

  # Power management (Framework laptop battery life)
  power-profiles-daemon

  # Btrfs snapshots + auto pre/post around pacman + grub boot-into-snapshot
  snapper snap-pac grub-btrfs inotify-tools

  # LTS kernel as a fallback — boot menu offers it when mainline breaks
  linux-lts linux-lts-headers

  # Pacman mirror auto-refresh (weekly via reflector.timer)
  reflector

  # CLI utilities
  git git-delta github-cli jq fd ripgrep fzf eza zoxide atuin wget less man-db unzip openssh

  # Local LLM runner — hosts embedding model for pi-knowledge-search
  # (nomic-embed-text). Model lives in /usr/share/ollama/.ollama after
  # first `ollama pull`. Daemon listens on 127.0.0.1:11434.
  ollama
  wl-clipboard

  # TUIs & shell goodies
  lazygit lazydocker htop fastfetch

  # Laptop documentation site (rendered from ~/.local/share/chezmoi/docs/)
  mdbook

  # Virtualization stack — KVM/QEMU + libvirt + virt-manager GUI.
  # edk2-ovmf = UEFI firmware (required by Win11). swtpm = software TPM 2.0
  # (also Win11 requirement). virtiofsd = host↔guest shared folder.
  # dnsmasq is pulled in transitively by libvirt for the default NAT network.
  qemu-full libvirt virt-manager edk2-ovmf swtpm virtiofsd

  # Fonts (powerline glyphs in tmux theme & waybar)
  ttf-jetbrains-mono-nerd

  # Self-management (yay is AUR-only; bootstrap manually first — see README)
  chezmoi
)

AUR_PKGS=(
  1password

  # zsh plugin manager (note: distinct from the unrelated French app 'antidote')
  zsh-antidote

  # Logout menu for Hyprland
  wlogout

  # Framework laptop EC tooling (battery charge limit, fan curves, etc.)
  fw-ectool-git

  # Smart tmux session manager (zoxide-aware)
  sesh-bin

  # Windows VM paravirt drivers + guest tools ISO. Mounts inside the Win11
  # installer to provide virtio storage/net drivers, plus spice-vdagent
  # for clipboard, dynamic resize, and USB redirection.
  virtio-win
)

echo "==> Installing pacman packages..."
sudo pacman -S --needed --noconfirm "${PACMAN_PKGS[@]}"

if command -v yay >/dev/null 2>&1; then
  echo "==> Installing AUR packages via yay..."
  yay -S --needed --noconfirm --aur "${AUR_PKGS[@]}"
else
  echo "WARN: yay not found; skipping AUR packages: ${AUR_PKGS[*]}"
  echo "      Install yay first, then re-run: chezmoi apply"
fi

# Virtualization one-time setup: group memberships + libvirtd service +
# default NAT network autostart + qemu user/group set to current user (so
# VM disks under \$HOME are readable/writable by the qemu process; the
# default `root` qemu user creates ownership churn in home-dir image
# stores). Guarded so the sudo block only fires when state actually needs
# fixing (faillock lesson: one sudo invocation per bash call, and skip
# entirely on the common re-run path).
QEMU_CONF=/etc/libvirt/qemu.conf
if ! id -nG "$USER" | grep -qw libvirt \
   || ! id -nG "$USER" | grep -qw kvm \
   || ! systemctl is-enabled --quiet libvirtd.service 2>/dev/null \
   || ! systemctl is-active  --quiet libvirtd.service 2>/dev/null \
   || ! virsh -c qemu:///system net-info default 2>/dev/null | grep -q '^Autostart:.*yes' \
   || ! grep -qE "^user\s*=\s*\"$USER\"" "$QEMU_CONF" 2>/dev/null \
   || ! grep -qE "^group\s*=\s*\"$USER\"" "$QEMU_CONF" 2>/dev/null; then
  echo "==> Configuring virtualization (groups, libvirtd, default network, qemu.conf user)..."
  sudo sh -c "
    set -e
    usermod -aG libvirt,kvm '$USER'

    # qemu.conf: run qemu as the user (not root) so VM disks under \$HOME
    # are readable/writable without ownership churn. Idempotent.
    if ! grep -qE '^user\s*=\s*\"$USER\"' '$QEMU_CONF'; then
      cp '$QEMU_CONF' '$QEMU_CONF.bak.\$(date +%Y%m%d%H%M%S)'
      sed -i \
        -e 's/^#user = \"libvirt-qemu\"/user = \"$USER\"/' \
        -e 's/^#group = \"libvirt-qemu\"/group = \"$USER\"/' \
        '$QEMU_CONF'
      # If the commented sentinel lines aren't there (e.g., already edited
      # by hand), append a definitive override at end of file.
      grep -qE '^user\s*=\s*\"$USER\"' '$QEMU_CONF' || \
        printf '\nuser = \"$USER\"\ngroup = \"$USER\"\n' >> '$QEMU_CONF'
    fi

    systemctl enable --now libvirtd.service
    systemctl restart libvirtd.service
    # Wait briefly for libvirtd socket to come up before talking to it.
    for _ in 1 2 3 4 5; do
      [ -S /var/run/libvirt/libvirt-sock ] && break
      sleep 1
    done
    virsh net-autostart default 2>/dev/null || true
    virsh net-info default 2>/dev/null | grep -q 'Active:.*yes' || virsh net-start default 2>/dev/null || true
  "
  echo "    Note: log out and back into Hyprland to pick up new group membership."
fi

# Switch login shell to zsh if it isn't already.
if [ "$(getent passwd "$USER" | cut -d: -f7)" != "$(command -v zsh)" ]; then
  echo "==> Changing login shell to zsh..."
  chsh -s "$(command -v zsh)"
fi

echo "==> Package install complete."
{{ end -}}
{{ end -}}
