#!/usr/bin/env bash
# hypr-screenshot — capture a screenshot via grim/slurp and open in swappy.
# Usage:
#   hypr-screenshot region   # interactive region (slurp)
#   hypr-screenshot window   # currently focused window
#   hypr-screenshot output   # entire focused monitor
#
# Bound from hyprland.conf. Saves a copy to ~/Pictures/Screenshots and pipes
# to swappy for annotation; swappy can re-save or copy to clipboard.

set -euo pipefail

mode="${1:-region}"
ts="$(date +%Y%m%d-%H%M%S)"
dir="$HOME/Pictures/Screenshots"
mkdir -p "$dir"
file="$dir/screenshot-$ts.png"

case "$mode" in
  region)
    geom="$(slurp -d 2>/dev/null)" || exit 0   # cancelled
    grim -g "$geom" "$file"
    ;;
  window)
    geom="$(hyprctl activewindow -j | jq -r '"\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"')"
    grim -g "$geom" "$file"
    ;;
  output)
    monitor="$(hyprctl monitors -j | jq -r '.[] | select(.focused==true) | .name')"
    grim -o "$monitor" "$file"
    ;;
  *)
    echo "usage: $0 {region|window|output}" >&2
    exit 2
    ;;
esac

# Open in swappy for annotation. swappy's Ctrl+C / Copy button now works
# reliably because wl-clip-persist (exec-once'd from hyprland.conf) keeps
# the clipboard offer alive after swappy exits — so the annotated image
# survives. Only fall back to wl-copy'ing the unannotated original if the
# user dismissed swappy without copying (i.e. no image is on the clipboard).
swappy -f "$file"

has_image_on_clipboard() {
  command -v wl-paste >/dev/null 2>&1 && \
    wl-paste --list-types 2>/dev/null | grep -q '^image/'
}

if ! has_image_on_clipboard; then
  newest="$(ls -t "$dir"/screenshot-*.png 2>/dev/null | head -1)"
  if [ -n "$newest" ] && command -v wl-copy >/dev/null 2>&1; then
    wl-copy --type image/png < "$newest"
    if command -v notify-send >/dev/null 2>&1; then
      notify-send -a "Screenshot" -t 2500 \
        "Screenshot copied to clipboard" \
        "$(basename "$newest")"
    fi
  fi
fi
