# Prompt: starship (see ~/.config/starship.toml).
eval "$(starship init zsh)"

# Secrets live in 1Password (see ~/.config/op-dev.env). We resolve them
# lazily, on-demand, per-command — NOT at shell startup.
#
# Implementation note: we deliberately do NOT use `op run --env-file=...`
# as a wrapper here. `op run` masks secrets in child stdout/stderr by
# pipe-interposing, which destroys the child's TTY — breaking pi's TUI
# (renders half-screen, can't exit) and claude (errors with "use stdin
# or --print"). Instead we resolve each op:// ref via `op read` directly
# in a subshell, export the values into that subshell's env, and `exec`
# into the target command. The target inherits the env normally and
# keeps its full TTY. Secrets never touch the parent shell.
#
# Offline note: works as long as the 1Password desktop app is running
# and unlocked (vault cached locally). Failures surface as explicit op
# errors, not silent empty env vars.
with-secrets() {
  (
    local key ref val
    while IFS='=' read -r key ref; do
      [[ "$key" =~ ^[A-Z_][A-Z0-9_]*$ ]] || continue
      ref=${ref#\"}; ref=${ref%\"}
      [[ "$ref" == op://* ]] || continue
      val=$(op read "$ref" 2>/dev/null) || {
        printf 'with-secrets: failed to read %s\n' "$ref" >&2
        return 1
      }
      [[ -n "$val" ]] && export "$key=$val"
    done < "$HOME/.config/op-dev.env"
    exec "$@"
  )
}

# Auto-inject for known TUI consumers.
command -v op >/dev/null 2>&1 && {
  alias pi='with-secrets pi-safe'
  alias claude='with-secrets claude'
}

# Initialize completion system. Required before antidote loads plugins that
# register completions via `compdef` (e.g. omz git plugin).
autoload -Uz compinit && compinit

# Plugin manager: antidote (https://getantidote.github.io/).
# Plugin list: ~/.zsh_plugins.txt
source /usr/share/zsh-antidote/antidote.zsh
antidote load

# zsh-autosuggestions tuning ---------------------------------------------------
# Default fg=8 is invisible on many terminals. Use Catppuccin overlay0.
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=#6c7086'
# Combine history + completions for richer suggestions.
ZSH_AUTOSUGGEST_STRATEGY=(history completion)
# Accept full suggestion with Ctrl-Space (in addition to default → and End).
bindkey '^ ' autosuggest-accept

# --- ls replacement: eza ----------------------------------------------------
if command -v eza >/dev/null 2>&1; then
  alias ls='eza --group-directories-first --icons=auto'
  alias ll='eza -l --group-directories-first --icons=auto --git'
  alias la='eza -la --group-directories-first --icons=auto --git'
  alias lt='eza --tree --level=2 --icons=auto'
  alias lta='eza --tree --level=2 --icons=auto -a'
fi

# --- zoxide: smarter cd (`z <partial>` jumps to frecent dirs, `zi` fuzzy) ---
# Sesh already uses zoxide's db for session matching; this exposes `z`/`zi`
# directly in the shell. Run last so it can override compinit-registered cd.
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init zsh)"

# --- tmux helpers (restored from old oh-my-zsh tmux plugin) -----------------
# ts [name]  → new session (named if arg given)
# ta [name]  → attach (to named session if arg given)
ts() {
  if [[ -z $1 || ${1:0:1} == '-' ]]; then tmux new-session "$@"
  else tmux new-session -s "$@"; fi
}
ta() {
  if [[ -z $1 || ${1:0:1} == '-' ]]; then tmux attach "$@"
  else tmux attach -t "$@"; fi
}

# --- PATH (deduplicated via typeset -U; leftmost wins) -----------------------
typeset -U PATH path
export ANDROID_HOME="$HOME/Android/Sdk"
export BUN_INSTALL="$HOME/.bun"
path=(
  /opt/nvim-linux64/bin
  $HOME/.local/bin
  $BUN_INSTALL/bin
  $HOME/go/bin
  /usr/local/go/bin
  $ANDROID_HOME/platform-tools
  $ANDROID_HOME/emulator
  $ANDROID_HOME/tools
  $ANDROID_HOME/tools/bin
  $path
)
export PATH

# --- Lazy-load nvm, but eagerly expose the default node's bin ---------------
# Sourcing nvm.sh is the slow part (~250ms); adding the bin dir to PATH is free.
# This makes every globally-installed npm CLI (pi, tsc, prettier, …) work
# immediately, while still deferring nvm.sh until you actually switch versions.
export NVM_DIR="$HOME/.nvm"

if [ -d "$NVM_DIR/versions/node" ]; then
  _nvm_v="default"
  while [ -f "$NVM_DIR/alias/$_nvm_v" ]; do
    _nvm_v=$(<"$NVM_DIR/alias/$_nvm_v")
  done
  if [ ! -d "$NVM_DIR/versions/node/$_nvm_v" ]; then
    _nvm_v=$(ls "$NVM_DIR/versions/node" | sort -V | tail -1)
  fi
  [ -d "$NVM_DIR/versions/node/$_nvm_v/bin" ] && \
    PATH="$NVM_DIR/versions/node/$_nvm_v/bin:$PATH"
  unset _nvm_v
fi

_nvm_load() {
  unset -f nvm _nvm_load
  [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
  [ -s "$NVM_DIR/bash_completion" ] && . "$NVM_DIR/bash_completion"
}
nvm() { _nvm_load; nvm "$@"; }

# --- bun completions ---------------------------------------------------------
[ -s "$BUN_INSTALL/_bun" ] && source "$BUN_INSTALL/_bun"

# --- Tool completions (cached weekly under ~/.cache/zsh/) --------------------
_zsh_cache="${ZSH_CACHE_DIR:-$HOME/.cache/zsh}"
mkdir -p "$_zsh_cache"
for _tool in kubectl helm minikube skaffold; do
  command -v "$_tool" >/dev/null 2>&1 || continue
  _file="$_zsh_cache/_$_tool.zsh"
  if [[ ! -f $_file || -n $(find "$_file" -mtime +7 2>/dev/null) ]]; then
    "$_tool" completion zsh > "$_file" 2>/dev/null
  fi
  source "$_file"
done
unset _zsh_cache _tool _file

# --- AWS CLI completion (uses aws_completer, bash-style) ---------------------
if command -v aws_completer >/dev/null 2>&1; then
  autoload -Uz bashcompinit && bashcompinit
  complete -C aws_completer aws
fi

# --- Greeting (interactive terminals only, skip inside tmux/zellij/ssh) ------
if [[ -o interactive && -z "$TMUX" && -z "$ZELLIJ" && -z "$SSH_TTY" ]] && \
   command -v fastfetch >/dev/null 2>&1; then
  fastfetch
fi
